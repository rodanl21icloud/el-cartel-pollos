{
  "name": "@cartel/backend",
  "version": "0.1.0",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --env-file=.env --watch src/index.js",
    "start": "node src/index.js",
    "db:push": "node --env-file=.env scripts/applySchema.js",
    "db:seed": "node --env-file=.env scripts/applySchema.js --seed",
    "seed:users": "node --env-file=.env scripts/seedUsers.js",
    "seed:carta": "node --env-file=.env scripts/seedCarta.mjs",
    "seed:recetas": "node --env-file=.env scripts/seedRecetas.mjs",
    "seed:recetas-real": "node --env-file=.env scripts/seedRecetasReal.mjs",
    "backup": "node --env-file=.env scripts/backup.mjs",
    "provision": "node scripts/provision.mjs",
    "provision:local": "node --env-file=.env.production scripts/provision.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@libsql/client": "^0.14.0",
    "bcryptjs": "^2.4.3",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "otplib": "^12.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "supertest": "^7.2.2",
    "vitest": "^4.1.8"
  }
}
