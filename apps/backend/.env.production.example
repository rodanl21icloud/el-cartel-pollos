# Plantilla de variables para PRODUCCIÓN.
# Copia a apps/backend/.env.production y complétala SOLO para provisionar la
# base remota desde tu máquina (npm run provision:local). NO la subas al repo.

# Turso (libSQL) — obtén estos valores con la CLI de Turso (ver DEPLOY.md):
#   turso db show --url <nombre>
#   turso db tokens create <nombre>
TURSO_DATABASE_URL=libsql://tu-base.turso.io
TURSO_AUTH_TOKEN=eyJ...token...

# Usuario gerencia inicial (opcional). Si omites ADMIN_PASSWORD se genera una fuerte.
ADMIN_USER=gerente
# ADMIN_PASSWORD=CambiaEstaClaveFuerte

# Solo para correr el servidor localmente contra la base remota (no en Render):
# NODE_ENV=production
# JWT_SECRET=genera-uno-largo-y-aleatorio
# JWT_TTL=12h
# PORT=3000
